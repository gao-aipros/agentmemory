# AgentMemory v2 — Environment Variable Reference
#
# Copy this file to .env or set these variables in your environment.
# All variables are read via os.Getenv / os.LookupEnv (no dotenv library needed).
#
# Usage:
#   cp .env.example .env
#   # edit .env, then start the server
#   go run cmd/agentmemory/main.go serve --db-url "$DB_URL"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string (ParadeDB with pgvector + BM25).
# Required, but typically set via docker-compose.yml or the --db-url CLI flag.
# DB_URL=

# Maximum number of connections in the pool.
# DB_MAX_CONNS=25

# Minimum number of idle connections kept alive.
# DB_MIN_CONNS=5

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# HTTP server port (single binary; REST + MCP + WebSocket + viewer on one port).
# PORT=8080

# Run database migrations automatically when the server starts.
# MIGRATE_ON_STARTUP=false

# Requests-per-second rate limit per client IP (applied by middleware).
# AGENTMEMORY_RATE_LIMIT=100

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# JWT signing secret. REQUIRED — no hardcoded fallback.
# Use a long random string in production.
JWT_SECRET=

# JWT token lifetime as a Go duration string.
# JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# LLM (language model for summarization, consolidation, crystallize, reflect)
# -----------------------------------------------------------------------------

# LLM provider: "openai-compatible", "openai", or "anthropic".
# Defaults to "openai-compatible" in code when left unset.
# LLM_PROVIDER=openai-compatible

# API key for the LLM provider. Highest priority key.
# Without an LLM key the server runs in zero-LLM mode (BM25 + local embeddings only).
# LLM_API_KEY=

# Model name sent to the LLM provider. Provider default if unset.
# LLM_MODEL=

# Base URL override for LLM requests (e.g. local proxy, Azure endpoint).
# LLM_BASE_URL=

# Deprecated: use LLM_API_KEY instead.
# OPENAI_API_KEY=

# Deprecated: use LLM_API_KEY instead.
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Embeddings (vector embeddings for semantic search)
# -----------------------------------------------------------------------------

# Embedding provider: "openai-compatible" or "openai".
# Defaults to "openai-compatible" in code when left unset.
# EMBEDDING_PROVIDER=openai-compatible

# API key for the embedding provider. Falls back to LLM_API_KEY, then OPENAI_API_KEY.
# EMBEDDING_API_KEY=

# Embedding model name. Provider default if unset.
# EMBEDDING_MODEL=

# Base URL override for embedding requests.
# EMBEDDING_BASE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Inject memory context into agent prompts at session start / pre-tool-use.
# Accepts "true", "1", or "yes". Off by default (costs LLM tokens).
# AGENTMEMORY_INJECT_CONTEXT=false

# Share consolidated memories across team members in MemberChoice mode.
# AGENTMEMORY_SHARE_CONSOLIDATED=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Minimum log level: "debug", "info", "warn", "error".
# LOG_LEVEL=info

# Log format: "text" (human-readable) or "json" (structured).
# LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Connect CLI (agentmemory connect)
# -----------------------------------------------------------------------------

# Agent token used by the connect command to register a new agent.
# CLI flag --token overrides this value.
# AGENTMEMORY_TOKEN=

# -----------------------------------------------------------------------------
# Scheduler (multi-tier batch pipeline)
# -----------------------------------------------------------------------------

# Interval (as Go duration, e.g. "60m", "1h") between compression runs.
# Set to 0 to disable compression.
# COMPRESSION_INTERVAL_MINUTES=60

# Interval between summarization runs. Requires compression to be enabled.
# SUMMARIZATION_INTERVAL_MINUTES=120

# Interval between consolidation runs. Requires summarization to be enabled.
# CONSOLIDATION_INTERVAL_MINUTES=360

# Interval between reflection runs. Requires consolidation to be enabled.
# REFLECTION_INTERVAL_MINUTES=1440

# -----------------------------------------------------------------------------
# Integration Tests Only
# -----------------------------------------------------------------------------

# Database URL used by integration tests (go test -tags=integration ./tests/integration/).
# Not read by production code.
# AGENTMEMORY_DATABASE_URL=postgres://agentmemory:agentmemory@localhost:5432/agentmemory?sslmode=disable
