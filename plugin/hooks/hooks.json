{
  "hooks": {
    "SessionStart": [
      {
        "tool": "memory_inject_context",
        "args": {
          "trigger": "session_start"
        }
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "tool": "memory_inject_context",
        "args": {
          "trigger": "pre_tool_use"
        }
      }
    ],
    "PreCompact": [
      {
        "tool": "memory_inject_context",
        "args": {
          "trigger": "pre_compact"
        }
      }
    ]
  }
}
